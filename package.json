{
  "name": "transformer",
  "productName": "Transformer",
  "version": "0.1.0-beta.1",
  "license": "GPL-3.0",
  "private": true,
  "description": "Local-only DJ audio preparation and conversion.",
  "author": "lhommeduchili",
  "homepage": "https://github.com/lhommeduchili/transformer",
  "repository": {
    "type": "git",
    "url": "https://github.com/lhommeduchili/transformer.git"
  },
  "main": "desktop-dist/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:web",
    "build:web": "tsc -b && vite build --mode web",
    "build:desktop": "tsc -b && vite build --mode desktop && node scripts/build-desktop.mjs",
    "desktop": "npm run build:desktop && electron .",
    "package:desktop": "node scripts/require-node-22.mjs && npm run build:desktop && electron-forge package",
    "make:desktop": "node scripts/require-node-22.mjs && node scripts/prepare-desktop-makers.mjs && npm run build:desktop && electron-forge make",
    "make:mac:arm64": "node scripts/require-node-22.mjs && node scripts/prepare-desktop-makers.mjs && npm run build:desktop && electron-forge make --platform=darwin --arch=arm64",
    "make:mac:x64": "node scripts/require-node-22.mjs && node scripts/prepare-desktop-makers.mjs && npm run build:desktop && electron-forge make --platform=darwin --arch=x64",
    "make:windows:x64": "node scripts/require-node-22.mjs && npm run build:desktop && electron-forge make --platform=win32 --arch=x64",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:electron": "playwright test --config=playwright.electron.config.ts",
    "arch": "depcruise src --config .dependency-cruiser.cjs"
  },
  "dependencies": {
    "@ffmpeg/core": "0.12.9",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "electron-squirrel-startup": "^1.0.1",
    "react": "latest",
    "react-dom": "latest",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "latest",
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@electron/osx-sign": "^1.3.3",
    "@eslint/js": "latest",
    "@playwright/test": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "dependency-cruiser": "latest",
    "electron": "^43.1.1",
    "esbuild": "^0.28.1",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "jsdom": "latest",
    "png-to-ico": "^3.0.1",
    "prettier": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vite": "latest",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "latest"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "electron-winstaller@5.4.4": true,
    "fs-xattr@0.3.1": true,
    "macos-alias@0.2.12": true,
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true
  }
}
